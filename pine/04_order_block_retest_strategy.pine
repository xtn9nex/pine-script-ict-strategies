//@version=6
// ============================================================================
//  ICT Order Block Retest — Phase 4: Retest Detection + Trade Execution
// ----------------------------------------------------------------------------
//  Builds on Phase 3 (zone lifecycle). This is now a STRATEGY: ARMED zones that
//  get retested are traded.
//
//      FORMED ──> ARMED ──> ACTIVE ──> DEAD
//
//  Entry   : at the configured retest trigger level (default 50% mean
//            threshold; proximal / distal selectable). Two entry styles:
//              - Passive limit       : resting limit order at the level.
//              - Confirmation candle : market entry once price reaches the
//                                      level AND a candle closes in-direction.
//  Stop    : beyond the DISTAL edge (+ buffer).
//  Target  : R multiple (default 2R) or structure (recent opposing swing).
//  One-shot: each OB is traded at most once; one position at a time.
//
//  NOTE: chart-timeframe detection for validation. Path A multi-timeframe
//  wiring (HTF context -> LTF execution) is added in a later step. Detection
//  stays in pure f_* functions so that wrapping is a drop-in change.
// ============================================================================

strategy("ICT Order Block Retest — Phase 4", overlay = true, initial_capital = 10000, default_qty_type = strategy.percent_of_equity, default_qty_value = 10, pyramiding = 0, calc_on_order_fills = false, process_orders_on_close = true, max_lines_count = 500, max_boxes_count = 500, max_labels_count = 500)

// ----------------------------------------------------------------------------
//  Inputs
// ----------------------------------------------------------------------------
grpSwing = "Swings (Pivots)"
pivotLeft  = input.int(5, "Pivot lookback — left",  minval = 1, group = grpSwing)
pivotRight = input.int(5, "Pivot lookback — right", minval = 1, group = grpSwing)

grpDisp = "Displacement / OB qualification"
requireFVG = input.bool(true,  "Require FVG in displacement", group = grpDisp)
requireBOS = input.bool(true,  "Require BOS in displacement", group = grpDisp)
fvgWindow  = input.int(5,  "FVG lookback window (bars)", minval = 1, group = grpDisp)
obMaxBack  = input.int(10, "Max bars to search back for OB candle", minval = 1, group = grpDisp)
useATR     = input.bool(false, "Require impulse > ATR multiple", group = grpDisp)
atrLen     = input.int(14,  "ATR length", minval = 1, group = grpDisp)
atrMult    = input.float(1.5, "ATR multiple", minval = 0.1, step = 0.1, group = grpDisp)

grpOB = "Order Blocks"
obBodyOnly = input.bool(false, "Zone = body only (open/close)", group = grpOB)
extendBars = input.int(5,  "Live zone forward projection (bars)", minval = 0, group = grpOB)
maxOBs     = input.int(15, "Max OBs to keep on chart", minval = 1, group = grpOB)
showMid    = input.bool(true, "Show 50% mean threshold line", group = grpOB)

grpLife = "Lifecycle"
expiryBars      = input.int(100, "Expiry: bars without retest", minval = 1, group = grpLife)
useExpiry       = input.bool(true,  "Enable time expiry", group = grpLife)
killOnOppBOS    = input.bool(true,  "Kill on opposing BOS", group = grpLife)
keepDeadOnChart = input.bool(true,  "Keep dead zones on chart (greyed)", group = grpLife)

grpTrade = "Trade Execution"
retestMode = input.string("50% Mean Threshold", "Retest trigger level", options = ["50% Mean Threshold", "Proximal Edge", "Distal Edge"], group = grpTrade)
entryStyle = input.string("Passive limit", "Entry style", options = ["Passive limit", "Confirmation candle"], group = grpTrade)
targetMode = input.string("R Multiple", "Target mode", options = ["R Multiple", "Structure"], group = grpTrade)
rMultiple  = input.float(2.0, "Reward multiple (R)", minval = 0.1, step = 0.1, group = grpTrade)
stopBufTicks = input.float(2.0, "Stop buffer (ticks beyond distal)", minval = 0.0, group = grpTrade)
tradeLong  = input.bool(true, "Allow long trades", group = grpTrade)
tradeShort = input.bool(true, "Allow short trades", group = grpTrade)
showTradeMarks = input.bool(true, "Mark executed trades across history", group = grpTrade)

grpStyle = "Style"
colBull    = input.color(color.teal, "Bullish OB color", group = grpStyle)
colBear    = input.color(color.red,  "Bearish OB color", group = grpStyle)
obOpacity  = input.int(82, "Armed fill transparency", minval = 0, maxval = 100, group = grpStyle)
showLegend = input.bool(true, "Show legend", group = grpStyle)

// ----------------------------------------------------------------------------
//  Pure detection functions
// ----------------------------------------------------------------------------
f_pivotHigh(int l, int r) => ta.pivothigh(high, l, r)
f_pivotLow (int l, int r) => ta.pivotlow(low,  l, r)

f_bullFVG() => low > high[2]
f_bearFVG() => high < low[2]

f_findOB(bool bull, int startOff, int maxBack) =>
    int res = -1
    for i = startOff to startOff + maxBack
        bool opposing = bull ? (close[i] < open[i]) : (close[i] > open[i])
        if opposing
            res := i
            break
    res

f_obTop(int off, bool bodyOnly) => bodyOnly ? math.max(open[off], close[off]) : high[off]
f_obBot(int off, bool bodyOnly) => bodyOnly ? math.min(open[off], close[off]) : low[off]

// ----------------------------------------------------------------------------
//  OB record type (extended with trade fields)
// ----------------------------------------------------------------------------
type OB
    int    id
    int    originBar
    int    createdBar
    bool   bull
    float  top
    float  bot
    float  mid
    float  proximal
    float  distal
    string state     // FORMED | ARMED | ACTIVE | DEAD
    bool   tapped
    bool   traded     // has this OB already been selected for a trade
    box    bx
    line   midLn
    label  lbl

// Retest trigger level for an OB.
f_entryLevel(OB ob, string mode) =>
    mode == "Proximal Edge" ? ob.proximal : mode == "Distal Edge" ? ob.distal : ob.mid

// Find an OB in the store by its unique id; returns array index or -1.
f_indexById(array<OB> store, int id) =>
    int idx = -1
    if array.size(store) > 0
        for i = 0 to array.size(store) - 1
            if array.get(store, i).id == id
                idx := i
                break
    idx

// ----------------------------------------------------------------------------
//  Primitive evaluation
// ----------------------------------------------------------------------------
ph = f_pivotHigh(pivotLeft, pivotRight)
pl = f_pivotLow(pivotLeft, pivotRight)

var float lastSH   = na
var float lastSL   = na
var bool  shBroken = false
var bool  slBroken = false

if not na(ph)
    lastSH   := ph
    shBroken := false
if not na(pl)
    lastSL   := pl
    slBroken := false

bool bosUp   = false
bool bosDown = false
if not na(lastSH) and not shBroken and close > lastSH
    bosUp    := true
    shBroken := true
if not na(lastSL) and not slBroken and close < lastSL
    bosDown  := true
    slBroken := true

bool bullFVG = f_bullFVG()
bool bearFVG = f_bearFVG()

var int barsSinceBullFVG = 1000000
var int barsSinceBearFVG = 1000000
barsSinceBullFVG := bullFVG ? 0 : barsSinceBullFVG + 1
barsSinceBearFVG := bearFVG ? 0 : barsSinceBearFVG + 1

float atr = ta.atr(atrLen)
bool atrOk = not useATR or (high - low) >= atrMult * atr

bool fvgRecentBull = barsSinceBullFVG <= fvgWindow
bool fvgRecentBear = barsSinceBearFVG <= fvgWindow

bool bullTrigger = false
bool bearTrigger = false
if requireBOS and requireFVG
    bullTrigger := bosUp   and fvgRecentBull
    bearTrigger := bosDown and fvgRecentBear
else if requireBOS and not requireFVG
    bullTrigger := bosUp
    bearTrigger := bosDown
else if requireFVG and not requireBOS
    bullTrigger := bullFVG
    bearTrigger := bearFVG
else
    bullTrigger := bosUp   or bullFVG
    bearTrigger := bosDown or bearFVG

bullTrigger := bullTrigger and atrOk
bearTrigger := bearTrigger and atrOk

// ----------------------------------------------------------------------------
//  OB store + creation
// ----------------------------------------------------------------------------
var array<OB> obs = array.new<OB>()

f_addOB(array<OB> store, int id, bool bull, int off) =>
    int   obBar = bar_index - off
    float t     = f_obTop(off, obBodyOnly)
    float b     = f_obBot(off, obBodyOnly)
    float m     = (t + b) / 2.0
    float prox  = bull ? t : b
    float dist  = bull ? b : t
    color col   = bull ? colBull : colBear
    int   right = bar_index + extendBars
    box   bx    = box.new(obBar, t, right, b, border_color = col, bgcolor = color.new(col, obOpacity))
    line  ml    = na
    if showMid
        ml := line.new(obBar, m, right, m, color = col, style = line.style_dotted, width = 1)
    label lb = label.new(obBar, bull ? b : t, bull ? "Bull OB" : "Bear OB", yloc = yloc.price, style = bull ? label.style_label_up : label.style_label_down, color = color.new(col, 15), textcolor = color.white, size = size.tiny)
    OB ob = OB.new(id, obBar, bar_index, bull, t, b, m, prox, dist, "FORMED", false, false, bx, ml, lb)
    array.push(store, ob)
    if array.size(store) > maxOBs
        OB old = array.shift(store)
        box.delete(old.bx)
        line.delete(old.midLn)
        label.delete(old.lbl)

var int seq           = 0
var int lastBullOBbar = na
var int lastBearOBbar = na

if bullTrigger
    int off = f_findOB(true, 1, obMaxBack)
    if off >= 0
        int obBar = bar_index - off
        if na(lastBullOBbar) or obBar != lastBullOBbar
            lastBullOBbar := obBar
            f_addOB(obs, seq, true, off)
            seq += 1

if bearTrigger
    int off = f_findOB(false, 1, obMaxBack)
    if off >= 0
        int obBar = bar_index - off
        if na(lastBearOBbar) or obBar != lastBearOBbar
            lastBearOBbar := obBar
            f_addOB(obs, seq, false, off)
            seq += 1

// ----------------------------------------------------------------------------
//  Repaint an OB box/line according to its state
// ----------------------------------------------------------------------------
f_paint(OB ob) =>
    color base = ob.bull ? colBull : colBear
    if ob.state == "DEAD"
        box.set_bgcolor(ob.bx, color.new(color.gray, 92))
        box.set_border_color(ob.bx, color.new(color.gray, 65))
        box.set_border_style(ob.bx, line.style_dashed)
        if not na(ob.midLn)
            line.set_color(ob.midLn, color.new(color.gray, 75))
    else if ob.state == "ACTIVE"
        box.set_bgcolor(ob.bx, color.new(base, math.max(obOpacity - 35, 0)))
        box.set_border_color(ob.bx, base)
        box.set_border_width(ob.bx, 2)
    else if ob.tapped
        box.set_bgcolor(ob.bx, color.new(base, math.max(obOpacity - 25, 0)))
        box.set_border_color(ob.bx, base)
    else
        box.set_bgcolor(ob.bx, color.new(base, obOpacity))
        box.set_border_color(ob.bx, base)

// ----------------------------------------------------------------------------
//  Lifecycle state machine (FORMED -> ARMED, mitigation, death conditions)
// ----------------------------------------------------------------------------
if array.size(obs) > 0
    for i = 0 to array.size(obs) - 1
        OB ob = array.get(obs, i)
        if ob.state != "DEAD"
            box.set_right(ob.bx, bar_index + extendBars)
            if not na(ob.midLn)
                line.set_x2(ob.midLn, bar_index + extendBars)

            if ob.state == "FORMED" and (ob.bull ? close > ob.top : close < ob.bot)
                ob.state := "ARMED"

            bool invalid = ob.bull ? (close < ob.distal) : (close > ob.distal)
            bool oppBOS  = ob.bull ? bosDown : bosUp
            bool tap     = ob.bull ? (low <= ob.proximal and high >= ob.distal) : (high >= ob.proximal and low <= ob.distal)

            if ob.state == "ARMED" and bar_index > ob.createdBar and tap and not invalid and not ob.tapped
                ob.tapped := true

            // ACTIVE zones are not killed by these structural conditions; the
            // trade's own stop/target manages exit (handled below).
            if ob.state != "ACTIVE"
                bool expired = useExpiry and (not ob.tapped) and (bar_index - ob.createdBar > expiryBars)
                if invalid
                    ob.state := "DEAD"
                else if killOnOppBOS and oppBOS
                    ob.state := "DEAD"
                else if expired
                    ob.state := "DEAD"

            if ob.state == "DEAD" and not keepDeadOnChart
                box.delete(ob.bx)
                line.delete(ob.midLn)
                label.delete(ob.lbl)
            else
                f_paint(ob)

// ----------------------------------------------------------------------------
//  Trade execution — one position at a time, MARKET entry on a confirmed
//  retest. We detect the bar on which price actually reaches the trigger level
//  inside an ARMED zone, then fire a market order (guaranteed fill) with a
//  protective stop/target bracket. This avoids the resting-limit "never fills /
//  setup gets stuck" failure mode.
// ----------------------------------------------------------------------------
var int   curObId = -1
var bool  curBull = false
var float curSL   = na
var float curTP   = na
var bool  inTrade = false

// persistent executed-trade markers (created on fill, extended while the trade
// is open, then RELEASED — never deleted — so every historical trade stays
// marked across the whole backtest).
var line  trE = na
var line  trS = na
var line  trT = na
var label trL = na

// --- exit detection: the trade just closed (stop/target hit) --------------
if inTrade and strategy.position_size == 0
    int idx = f_indexById(obs, curObId)
    if idx >= 0
        OB oc = array.get(obs, idx)
        oc.state := "DEAD"
    if not na(trE)
        line.set_x2(trE, bar_index)
        line.set_x2(trS, bar_index)
        line.set_x2(trT, bar_index)
        trE := na
        trS := na
        trT := na
        trL := na
    inTrade := false
    curObId := -1

// --- fill detection: the trade just opened --------------------------------
if (not inTrade) and strategy.position_size != 0
    inTrade := true
    int idx = f_indexById(obs, curObId)
    if idx >= 0
        OB oa = array.get(obs, idx)
        oa.state := "ACTIVE"
    if showTradeMarks
        float ey = strategy.position_avg_price
        trE := line.new(bar_index, ey,    bar_index, ey,    color = color.new(color.blue, 0),  width = 2)
        trS := line.new(bar_index, curSL, bar_index, curSL, color = color.new(color.red, 0),   width = 1, style = line.style_dotted)
        trT := line.new(bar_index, curTP, bar_index, curTP, color = color.new(color.green, 0), width = 1, style = line.style_dotted)
        trL := label.new(bar_index, ey, curBull ? "▲ entry" : "▼ entry", yloc = yloc.price, style = curBull ? label.style_label_up : label.style_label_down, color = color.new(curBull ? colBull : colBear, 0), textcolor = color.white, size = size.tiny)

// --- entry: scan ARMED zones for a confirmed retest this bar --------------
if strategy.position_size == 0 and not inTrade and array.size(obs) > 0
    int   pick     = -1
    float bestDist = 1.0e18
    for i = 0 to array.size(obs) - 1
        OB o = array.get(obs, i)
        bool dirOk = o.bull ? tradeLong : tradeShort
        if o.state == "ARMED" and not o.traded and dirOk
            float E       = f_entryLevel(o, retestMode)
            bool  reached = o.bull ? (low <= E) : (high >= E)
            bool  valid   = o.bull ? (close >= o.distal) : (close <= o.distal)
            bool  confirm = entryStyle == "Confirmation candle" ? (o.bull ? close > open : close < open) : true
            if reached and valid and confirm
                float d = math.abs(close - E)   // nearest eligible zone first
                if d < bestDist
                    bestDist := d
                    pick := i
    if pick >= 0
        OB sel = array.get(obs, pick)
        sel.traded := true
        sel.state  := "ACTIVE"   // protect from lifecycle death while trading
        float E   = f_entryLevel(sel, retestMode)
        float buf = stopBufTicks * syminfo.mintick
        float SL  = sel.bull ? sel.distal - buf : sel.distal + buf
        float risk = math.abs(E - SL)
        float tpR  = sel.bull ? E + risk * rMultiple : E - risk * rMultiple
        float tpStruct = sel.bull ? lastSH : lastSL
        bool  structOk = not na(tpStruct) and (sel.bull ? tpStruct > E : tpStruct < E)
        float TP = (targetMode == "Structure" and structOk) ? tpStruct : tpR
        curObId := sel.id
        curBull := sel.bull
        curSL   := SL
        curTP   := TP
        string eid = "OB" + str.tostring(sel.id)
        strategy.entry(eid, sel.bull ? strategy.long : strategy.short)
        strategy.exit("X" + str.tostring(sel.id), from_entry = eid, stop = SL, limit = TP)

// --- keep the protective bracket attached for the whole trade -------------
if strategy.position_size != 0 and curObId >= 0
    strategy.exit("X" + str.tostring(curObId), from_entry = "OB" + str.tostring(curObId), stop = curSL, limit = curTP)

// --- extend the persistent trade marker while the trade is open -----------
if inTrade and showTradeMarks and not na(trE)
    line.set_x2(trE, bar_index)
    line.set_x2(trS, bar_index)
    line.set_x2(trT, bar_index)

// ----------------------------------------------------------------------------
//  Legend
// ----------------------------------------------------------------------------
if showLegend and barstate.islast
    var table legend = table.new(position.top_right, 1, 8, border_width = 1)
    table.cell(legend, 0, 0, "ICT OB Retest — Phase 4", text_color = color.white, bgcolor = color.new(color.gray, 20), text_size = size.small)
    table.cell(legend, 0, 1, "Solid fill   = ARMED (waiting)", text_color = color.white, bgcolor = color.new(color.black, 30), text_size = size.tiny)
    table.cell(legend, 0, 2, "Bold border  = ACTIVE (in trade)", text_color = color.white, bgcolor = color.new(color.black, 30), text_size = size.tiny)
    table.cell(legend, 0, 3, "Grey dashed  = DEAD", text_color = color.white, bgcolor = color.new(color.black, 30), text_size = size.tiny)
    table.cell(legend, 0, 4, "Blue  = Entry  (" + retestMode + ")", text_color = color.blue,  bgcolor = color.new(color.black, 30), text_size = size.tiny)
    table.cell(legend, 0, 5, "Red   = Stop (beyond distal)", text_color = color.red,   bgcolor = color.new(color.black, 30), text_size = size.tiny)
    table.cell(legend, 0, 6, "Green = Target (" + targetMode + ")", text_color = color.green, bgcolor = color.new(color.black, 30), text_size = size.tiny)
    table.cell(legend, 0, 7, "Dotted spans = executed trades", text_color = color.white, bgcolor = color.new(color.black, 30), text_size = size.tiny)
